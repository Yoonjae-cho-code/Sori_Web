# ============================================================
#  SORI · 소리 — Environment Variables
#  Copy this file to .env and fill in your keys.
#  .env is gitignored — never commit real keys.
# ============================================================

# ── Anthropic (Claude — LLM analysis) ──────────────────────
# Required. Used for psychological mirror text generation.
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (Whisper — STT) ─────────────────────────────────
# Required. Used for in-memory audio transcription only.
# Audio is never stored — see server.js privacy comment.
OPENAI_API_KEY=sk-...

# ── Server ─────────────────────────────────────────────────
PORT=3000

# ── CORS ───────────────────────────────────────────────────
# Frontend origin — set to your dev server / production domain.
CLIENT_ORIGIN=http://localhost:5500
